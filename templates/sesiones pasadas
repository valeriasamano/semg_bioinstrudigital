<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Historial de Sesiones - sEMG</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body class="bg-[#F8FAFC] text-slate-900 font-sans">

    <nav class="bg-white border-b border-slate-200 py-4 px-8 flex justify-between items-center shadow-sm">
        <div class="flex items-center gap-3">
            <h1 class="text-xl font-bold tracking-tighter text-slate-800 italic text-[14px]">Bioinstrumentación Digital - Historial</h1>
        </div>
        <div class="space-x-8 text-[10px] font-black uppercase tracking-widest flex items-center">
            <a href="/" class="text-slate-400 hover:text-blue-600 transition">Monitor</a>
            <a href="/sesiones" class="text-blue-600 border-b-2 border-blue-600 pb-1">Sesiones Pasadas</a>
            <a href="/logout" class="bg-red-50 text-red-500 px-4 py-2 rounded-full font-black">LogOut</a>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto p-8 animate-fade-in">
        <div class="mb-8">
            <h2 class="text-4xl font-light text-slate-800 italic">Historial de <strong>Sesiones Clínicas</strong></h2>
            <p class="text-slate-400 text-sm mt-2 font-medium">Registro histórico de mediciones de potencia muscular (RMS/ARV).</p>
        </div>

        <div class="bg-white rounded-[32px] shadow-sm border border-slate-100 overflow-hidden">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-100">
                        <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-slate-400">Fecha y Hora</th>
                        <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-slate-400">ID Paciente</th>
                        <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-slate-400">Doctor/Personal</th>
                        <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-purple-600 text-center">RMS (mV)</th>
                        <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-cyan-600 text-center">ARV (mV)</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    {% for s in sesiones %}
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="px-8 py-5">
                            <p class="text-sm font-bold text-slate-700">{{ s.date_created.strftime('%d/%m/%Y') }}</p>
                            <p class="text-[10px] text-slate-400 font-mono">{{ s.date_created.strftime('%H:%M:%S') }}</p>
                        </td>
                        <td class="px-8 py-5 text-sm font-medium text-slate-600">{{ s.patient_id }}</td>
                        <td class="px-8 py-5 text-sm italic text-slate-500">{{ s.doctor_name }}</td>
                        <td class="px-8 py-5 text-center">
                            <span class="bg-purple-50 text-purple-600 px-4 py-1 rounded-full text-xs font-black">{{ s.rms_avg }}</span>
                        </td>
                        <td class="px-8 py-5 text-center">
                            <span class="bg-cyan-50 text-cyan-600 px-4 py-1 rounded-full text-xs font-black">{{ s.arv_avg }}</span>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="5" class="px-8 py-20 text-center text-slate-300 italic">No hay sesiones registradas aún.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </main>

    <style>
        .animate-fade-in { animation: fadeIn 0.5s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</body>
</html>
